# ---------------------------------------------------------------------------
# Local-first configuration — copy to .env.local (git-ignored). NO SECRETS.
# Every value has a working default, so the app runs even with an empty file:
#     cp .env.local.example .env.local
# ---------------------------------------------------------------------------

# data.gov.il datastore_search endpoint. Called SERVER-SIDE ONLY (never the browser).
GOV_API_BASE=https://data.gov.il/api/3/action/datastore_search

# Absolute base URL used for canonical links, Open Graph tags, sitemap and robots.
# Local default works out of the box; production sets this to the real domain.
SITE_URL=http://localhost:3000

# How long (in seconds) a fetched vehicle stays in the in-memory cache. Default: 24h.
CACHE_TTL_SECONDS=86400

# Cache backend. "memory" for the local-first build.
# (Migration only — do NOT enable now: "redis".)
CACHE_DRIVER=memory

# Per-IP rate limit for /api/vehicle/[plate]: up to RATE_LIMIT_MAX requests
# per RATE_LIMIT_WINDOW_MS window. Protects the gov quota + blocks enumeration.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Rate-limit backend. "memory" for the local-first build.
# (Migration only — do NOT enable now: a shared store.)
RATE_LIMIT_DRIVER=memory
